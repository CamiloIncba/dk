<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permiso de Internet para poder llamar al backend -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Permiso de vibración para notificaciones de cocina -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Bluetooth pre-Android 12 (hasta SDK 30) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Para Android 12+ (S) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" 
        android:usesPermissionFlags="neverForLocation" />

    <application
        android:name=".KioskoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KiskoApp"
        android:usesCleartextTraffic="true">

        <!-- Activity de configuración del servidor (compartido) -->
        <activity
            android:name=".settings.BackendConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar" />

        <!-- Activity de configuración de impresora Kiosko -->
        <activity
            android:name=".settings.KioskPrinterConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar" />

        <!-- Activity de configuración de impresora Cocina -->
        <activity
            android:name=".settings.KitchenPrinterConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar" />

        <!-- IMPORTANTE:
             No declaramos activities acá.
             Cada flavor (kiosk / kitchen) define su launcher en su manifest propio. -->

    </application>

</manifest>
