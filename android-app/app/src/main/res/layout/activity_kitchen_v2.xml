<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#16213e">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🍳 COCINA"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#ffffff" />

        <!-- Contadores -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/countActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activos: 0"
                android:textSize="16sp"
                android:textColor="#f59e0b"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/badge_orange"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/countReady"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listos: 0"
                android:textSize="16sp"
                android:textColor="#22c55e"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/badge_green"
                android:layout_marginEnd="16dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:minWidth="56dp"
            android:text="🔄"
            android:textSize="24sp"
            android:backgroundTint="#3b82f6"
            android:layout_marginEnd="8dp" />

        <!-- Indicador de conexión -->
        <LinearLayout
            android:id="@+id/connectionIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="@drawable/badge_green"
            android:layout_marginEnd="8dp">
            
            <View
                android:id="@+id/connectionDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dark"
                android:backgroundTint="#22c55e" />
            
            <TextView
                android:id="@+id/connectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conectado"
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Botón de configuración -->
        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:minWidth="56dp"
            android:text="⚙️"
            android:textSize="24sp"
            android:backgroundTint="#6b7280"
            android:layout_marginEnd="8dp" />

        <!-- Botón de impresoras -->
        <Button
            android:id="@+id/btnPrinter"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:minWidth="56dp"
            android:text="🖨️"
            android:textSize="24sp"
            android:backgroundTint="#8b5cf6" />
    </LinearLayout>

    <!-- Error text -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="#ef4444"
        android:textSize="16sp"
        android:visibility="gone"
        android:background="#2d1f1f" />

    <!-- Dos columnas: En Preparación | Listos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Columna EN PREPARACIÓN -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">

            <!-- Header columna -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#f59e0b">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 EN PREPARACIÓN"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/badgeActive"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:background="@drawable/circle_dark" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerActive"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1f2937"
                android:padding="8dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Columna LISTOS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <!-- Header columna -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#22c55e">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✅ LISTOS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/badgeReady"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:background="@drawable/circle_dark" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerReady"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#14532d"
                android:padding="8dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
