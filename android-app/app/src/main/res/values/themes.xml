<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema base: debe ser AppCompat porque KitchenMainActivity usa AppCompatActivity y widgets AppCompat -->
    <style name="Theme.KiskoApp" parent="Theme.AppCompat.Light.NoActionBar" />

    <!-- Alias por compatibilidad: algunos manifests/flavors apuntan a Theme.Kiosko -->
    <style name="Theme.Kiosko" parent="Theme.KiskoApp" />

    <!-- Tema oscuro para la app de cocina -->
    <style name="Theme.Kiosko.Kitchen" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#3b82f6</item>
        <item name="colorPrimaryDark">#1e3a5f</item>
        <item name="colorAccent">#22c55e</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

</resources>
