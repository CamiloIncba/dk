<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Necesario para pegarle al backend -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Bluetooth (legacy y Android 12+) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.Kiosko.Kitchen"
        tools:replace="android:theme">

        <!-- REMOVER el launcher del manifest base (MainActivity del kiosko) -->
        <activity
            android:name="com.norpan.kiosko.MainActivity"
            tools:node="remove" />

        <!-- Launcher de la cocina (versión mejorada) -->
        <activity
            android:name="com.norpan.kiosko.kitchen.KitchenMainActivityV2"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
