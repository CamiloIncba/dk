# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/kiosko_dev?schema=public"

# MercadoPago
MP_ACCESS_TOKEN="your_mp_access_token"
MP_WEBHOOK_URL="https://your-domain.com/payments/mp/webhook"

# App
APP_PUBLIC_BASE_URL="https://your-domain.com"
STORE_NAME="Tu Negocio"
STORE_ADDRESS="Dirección del local"

# Seguridad - API Key para endpoints protegidos (kitchen, admin)
# En producción, usar una clave larga y aleatoria
API_KEY="your-secret-api-key-here"

# AWS S3 - Subida de imágenes de productos
# Ver docs/AWS_S3_SETUP.md para instrucciones de configuración
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="tu-bucket-name"
